{
    "name": "homepage",
    "version": "0.0.1",
    "description": "Russell McWhae’s portfolio",
    "scripts": {
        "dev": "vite dev --port 4000 --host",
        "build": "rm -rf .vercel_build_output && vite build",
        "preview": "vite preview --port 4000",
        "kill": "rm -rf node_modules",
        "lint": "prettier --check . && eslint .",
        "format": "prettier --write .",
        "test": "playwright test",
        "test:ui": "playwright test --ui",
        "test:headed": "playwright test --headed",
        "test:debug": "playwright test --debug",
        "postinstall": "pnpm rebuild sharp"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@imagekit/nodejs": "^7.5.0",
        "@playwright/test": "^1.59.1",
        "@sveltejs/adapter-vercel": "^6.3.3",
        "@sveltejs/kit": "^2.57.1",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@types/node": "^25.6.0",
        "@types/unist": "^3.0.3",
        "@typescript-eslint/eslint-plugin": "^8.59.0",
        "@typescript-eslint/parser": "^8.59.0",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.17.1",
        "mdsvex": "^0.12.7",
        "node-gyp": "^12.3.0",
        "photoswipe": "^5.4.4",
        "prettier": "~3.8.3",
        "prettier-plugin-svelte": "^3.5.1",
        "rehype-autolink-headings": "^7.1.0",
        "rehype-external-links": "^3.0.0",
        "rehype-slug": "^6.0.0",
        "remark-gfm": "^4.0.1",
        "sass": "^1.99.0",
        "svelte": "^5.55.4",
        "svelte-gallery": "^1.3.5",
        "svelte-icons": "^2.1.0",
        "svimg": "^4.0.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.0",
        "vite": "^8.0.10"
    },
    "type": "module",
    "dependencies": {
        "@imagekit/javascript": "^5.3.0",
        "@vercel/analytics": "^2.0.1",
        "@vercel/speed-insights": "^2.0.0",
        "dateformat": "^5.0.3",
        "reading-time": "^1.5.0",
        "sharp": "^0.34.5",
        "unist-util-visit": "^5.1.0"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@vercel/speed-insights",
            "sharp"
        ],
        "ignoredBuiltDependencies": [
            "@parcel/watcher",
            "esbuild"
        ],
        "overrides": {
            "cookie@<0.7.0": ">=0.7.0",
            "yaml": ">=2.8.3"
        }
    }
}